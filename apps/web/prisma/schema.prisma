datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// =============================================================================
// USERS
// =============================================================================
model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  name            String?   @db.VarChar(255)
  username        String    @unique @db.VarChar(100)
  avatarUrl       String?   @map("avatar_url")
  role            String    @default("user") @db.VarChar(50)
  targetRole      String?   @map("target_role") @db.VarChar(100)
  targetCompanies String[]  @map("target_companies")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  accounts             Account[]
  sessions             Session[]
  githubProfile        GithubProfile?
  leetcodeProfile      LeetcodeProfile?
  resumes              Resume[]
  interviewSessions    InterviewSession[]
  hiringReadinessScore HiringReadinessScore?
  settings             UserSettings?
  auditLogs            AuditLog[]
  // problem_bank rows reviewed by this user (admin)
  reviewedProblems     ProblemBank[]         @relation("ProblemBankReviewer")

  @@index([email])
  @@index([username])
  @@map("users")
}

// =============================================================================
// AUTH — ACCOUNTS
// =============================================================================
model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  provider          String   @db.VarChar(50)
  providerAccountId String   @map("provider_account_id") @db.VarChar(255)
  accessToken       String?  @map("access_token")
  refreshToken      String?  @map("refresh_token")
  tokenType         String?  @map("token_type") @db.VarChar(50)
  scope             String?
  expiresAt         BigInt?  @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// =============================================================================
// AUTH — SESSIONS
// =============================================================================
model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  sessionToken String   @unique @map("session_token") @db.VarChar(500)
  expires      DateTime @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@index([userId])
  @@map("sessions")
}

model GithubProfile {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  githubUsername       String    @map("github_username") @db.VarChar(100)
  /// CHECK (github_score BETWEEN 0 AND 100) — enforced in migration SQL
  githubScore          Int?      @map("github_score") @db.SmallInt
  /// CHECK (repo_health_score BETWEEN 0 AND 100) — enforced in migration SQL
  repoHealthScore      Int?      @map("repo_health_score") @db.SmallInt
  /// CHECK (open_source_score BETWEEN 0 AND 100) — enforced in migration SQL
  openSourceScore      Int?      @map("open_source_score") @db.SmallInt
  totalRepos           Int       @default(0) @map("total_repos")
  totalStars           Int       @default(0) @map("total_stars")
  totalForks           Int       @default(0) @map("total_forks")
  totalCommitsYear     Int       @default(0) @map("total_commits_year")
  /// JSONB: {"JavaScript": 45, "Python": 30, ...}
  languageDistribution Json?     @map("language_distribution")
  /// JSONB: {"2024-01-01": 5, ...} — last 365 days contribution calendar
  contributionCalendar Json?     @map("contribution_calendar")
  /// JSONB: [{name, stars, forks, url, description}]
  topRepos             Json?     @map("top_repos")
  recommendations      String[]
  lastSyncedAt         DateTime? @map("last_synced_at") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("github_profiles")
}

// =============================================================================
// LEETCODE PROFILES
// =============================================================================
model LeetcodeProfile {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @unique @map("user_id") @db.Uuid
  leetcodeUsername String    @map("leetcode_username") @db.VarChar(100)
  /// CHECK (leetcode_score BETWEEN 0 AND 100) — enforced in migration SQL
  leetcodeScore    Int?      @map("leetcode_score") @db.SmallInt
  totalSolved      Int       @default(0) @map("total_solved")
  easySolved       Int       @default(0) @map("easy_solved")
  mediumSolved     Int       @default(0) @map("medium_solved")
  hardSolved       Int       @default(0) @map("hard_solved")
  contestRating    Int?      @map("contest_rating")
  contestRanking   Int?      @map("contest_ranking")
  streakDays       Int       @default(0) @map("streak_days")
  /// JSONB: {"Arrays": {"solved": 10, "total": 50}, ...}
  topicPerformance Json?     @map("topic_performance")
  weakTopics       String[]  @map("weak_topics")
  /// JSONB: [{slug, title, difficulty, url}]
  recommendations  Json?
  /// JSONB: [{date, rating, ranking, problemsSolved}]
  contestHistory   Json?     @map("contest_history")
  lastSyncedAt     DateTime? @map("last_synced_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("leetcode_profiles")
}

// =============================================================================
// RESUMES
// =============================================================================
model Resume {
  id            String @id @default(uuid()) @db.Uuid
  userId        String @map("user_id") @db.Uuid
  fileUrl       String @map("file_url")
  fileName      String @map("file_name") @db.VarChar(255)
  fileSizeBytes Int    @map("file_size_bytes")

  /// Only one resume per user should have is_active = TRUE at a time
  isActive Boolean @default(true) @map("is_active")

  /// CHECK (resume_score BETWEEN 0 AND 100) — enforced in migration SQL
  resumeScore Int? @map("resume_score") @db.SmallInt

  /// CHECK (ats_score BETWEEN 0 AND 100) — enforced in migration SQL
  atsScore Int? @map("ats_score") @db.SmallInt

  /// CHECK (formatting_score BETWEEN 0 AND 100) — enforced in migration SQL
  formattingScore Int? @map("formatting_score") @db.SmallInt

  /// CHECK (keyword_score BETWEEN 0 AND 100) — enforced in migration SQL
  keywordScore Int? @map("keyword_score") @db.SmallInt

  /// CHECK (impact_score BETWEEN 0 AND 100) — enforced in migration SQL
  impactScore     Int?     @map("impact_score") @db.SmallInt
  missingKeywords String[] @map("missing_keywords")

  /// JSONB: [{original, suggestion, reason}]
  weakBullets Json? @map("weak_bullets")

  /// JSONB: {summary: "...", experience: "...", ...}
  sectionFeedback Json? @map("section_feedback")

  /// pending | processing | complete | failed
  analysisStatus String    @default("pending") @map("analysis_status") @db.VarChar(50)
  analyzedAt     DateTime? @map("analyzed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("resumes")
}

// =============================================================================
// PROBLEM BANK
// =============================================================================
model ProblemBank {
  id          String @id @default(uuid()) @db.Uuid
  title       String @db.VarChar(255)
  description String

  /// JSONB: [{input, output, explanation}]
  examples    Json
  constraints String[]

  /// JSONB: [{input, expected_output}]
  testCasesVisible Json @map("test_cases_visible")

  /// JSONB: [{input, expected_output}] — not exposed to candidates
  testCasesHidden Json @map("test_cases_hidden")

  /// easy | medium | hard
  difficulty String @db.VarChar(20)

  /// arrays | trees | graphs | dp | strings | sorting | etc.
  topic String @db.VarChar(100)

  /// e.g. O(n log n)
  optimalTimeComplexity String? @map("optimal_time_complexity") @db.VarChar(50)

  /// e.g. O(n)
  optimalSpaceComplexity String? @map("optimal_space_complexity") @db.VarChar(50)

  /// JSONB: [{level: 1, text: "..."}, ...]
  hints    Json?
  tags     String[]
  isActive Boolean  @default(true) @map("is_active")

  /// FK to users(id) — the admin who reviewed/approved this problem
  reviewedById String?  @map("reviewed_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  reviewedBy        User?              @relation("ProblemBankReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  interviewProblems InterviewProblem[]

  // Composite index: (difficulty, topic, is_active) — added via raw SQL in migration
  @@map("problem_bank")
}

// =============================================================================
// INTERVIEW SESSIONS
// =============================================================================
model InterviewSession {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  /// in_progress | completed | abandoned
  status String @default("in_progress") @db.VarChar(50)

  /// easy | medium | hard
  difficulty      String    @db.VarChar(20)
  topic           String?   @db.VarChar(100)
  voiceEnabled    Boolean   @default(true) @map("voice_enabled")
  language        String    @default("javascript") @db.VarChar(50)
  durationSeconds Int?      @map("duration_seconds")
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem          InterviewProblem?
  submissions      InterviewSubmission[]
  scores           InterviewScores?
  voiceTranscripts VoiceTranscript[]

  @@index([userId])
  @@index([status])
  // Composite partial index — added via raw SQL in migration:
  @@map("interview_sessions")
}

// =============================================================================
// INTERVIEW PROBLEMS
// =============================================================================
model InterviewProblem {
  id        String @id @default(uuid()) @db.Uuid
  sessionId String @unique @map("session_id") @db.Uuid

  /// Nullable FK: set when problem was drawn from problem_bank; null for AI-generated ad-hoc problems
  problemBankId String? @map("problem_bank_id") @db.Uuid

  // ---- Snapshot columns (immutable after creation) ----
  title       String @db.VarChar(255)
  description String

  /// JSONB: [{input, output, explanation}]
  examples    Json
  constraints String[]

  /// JSONB: [{input, expected_output}]
  testCasesVisible Json @map("test_cases_visible")

  /// JSONB: [{input, expected_output}]
  testCasesHidden        Json    @map("test_cases_hidden")
  optimalTimeComplexity  String? @map("optimal_time_complexity") @db.VarChar(50)
  optimalSpaceComplexity String? @map("optimal_space_complexity") @db.VarChar(50)

  /// JSONB: [{level: 1, text: "..."}, ...]
  hints     Json?
  tags      String[]
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  session     InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  problemBank ProblemBank?     @relation(fields: [problemBankId], references: [id], onDelete: SetNull)

  @@index([problemBankId])
  @@map("interview_problems")
}

// =============================================================================
// INTERVIEW SUBMISSIONS
// =============================================================================
model InterviewSubmission {
  id        String @id @default(uuid()) @db.Uuid
  sessionId String @map("session_id") @db.Uuid
  code      String
  language  String @db.VarChar(50)

  /// TRUE = final graded submission; FALSE = intermediate run
  isFinal     Boolean @default(false) @map("is_final")
  judge0Token String? @map("judge0_token") @db.VarChar(100)

  /// JSONB: {stdout, stderr, time, memory, status, testCases[]}
  executionResult Json?    @map("execution_result")
  submittedAt     DateTime @default(now()) @map("submitted_at") @db.Timestamptz

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  // Partial index — added via raw SQL in migration:
  @@map("interview_submissions")
}

// =============================================================================
// INTERVIEW SCORES
// Score columns have CHECK (BETWEEN 0 AND 100) enforced in migration SQL.
// =============================================================================
model InterviewScores {
  id        String @id @default(uuid()) @db.Uuid
  sessionId String @unique @map("session_id") @db.Uuid

  /// CHECK (communication_score BETWEEN 0 AND 100) — enforced in migration SQL
  communicationScore Int? @map("communication_score") @db.SmallInt

  /// CHECK (dsa_score BETWEEN 0 AND 100) — enforced in migration SQL
  dsaScore Int? @map("dsa_score") @db.SmallInt

  /// CHECK (code_quality_score BETWEEN 0 AND 100) — enforced in migration SQL
  codeQualityScore Int? @map("code_quality_score") @db.SmallInt

  /// CHECK (optimization_score BETWEEN 0 AND 100) — enforced in migration SQL
  optimizationScore Int? @map("optimization_score") @db.SmallInt

  /// CHECK (overall_score BETWEEN 0 AND 100) — enforced in migration SQL
  overallScore Int? @map("overall_score") @db.SmallInt

  /// JSONB: {communication: "...", dsa: "...", ...}
  feedback     Json?
  improvements String[]

  /// Full AI code analysis output
  codeAnalysis Json? @map("code_analysis")

  /// Full AI communication analysis output
  communicationAnalysis Json? @map("communication_analysis")

  /// JSONB: {unchecked: [{name, severity}]}
  edgeCaseReport Json?    @map("edge_case_report")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("interview_scores")
}

// =============================================================================
// VOICE TRANSCRIPTS
// =============================================================================
model VoiceTranscript {
  id           String @id @default(uuid()) @db.Uuid
  sessionId    String @map("session_id") @db.Uuid
  segmentIndex Int    @map("segment_index")

  /// user | ai
  speaker     String @db.VarChar(20)
  text        String
  timestampMs Int?   @map("timestamp_ms")

  /// Speech recognition confidence 0.00–1.00
  confidence Decimal? @db.Decimal(3, 2)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("voice_transcripts")
}

// =============================================================================
// HIRING READINESS SCORES
// Score columns have CHECK (BETWEEN 0 AND 100) enforced in migration SQL.
// =============================================================================
model HiringReadinessScore {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  /// CHECK (overall_score BETWEEN 0 AND 100) — enforced in migration SQL
  overallScore Int? @map("overall_score") @db.SmallInt

  /// not_ready | building | interview_ready | competitive | faang_ready
  level              String? @db.VarChar(50)
  githubComponent    Int?    @map("github_component") @db.SmallInt
  leetcodeComponent  Int?    @map("leetcode_component") @db.SmallInt
  resumeComponent    Int?    @map("resume_component") @db.SmallInt
  interviewComponent Int?    @map("interview_component") @db.SmallInt

  /// JSONB: {weeks: [{week: 1, tasks: [{title, description, link}]}]}
  roadmap Json?

  /// JSONB: [{area, action, impact, effort}]
  improvementQueue Json?    @map("improvement_queue")
  computedAt       DateTime @default(now()) @map("computed_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hiring_readiness_scores")
}

// =============================================================================
// USER SETTINGS
// =============================================================================
model UserSettings {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  // Privacy
  profilePublic      Boolean @default(true) @map("profile_public")
  showGithubScore    Boolean @default(true) @map("show_github_score")
  showLeetcodeScore  Boolean @default(true) @map("show_leetcode_score")
  showInterviewScore Boolean @default(true) @map("show_interview_score")
  showResumeScore    Boolean @default(false) @map("show_resume_score")

  // Notifications
  emailWeeklyDigest Boolean @default(true) @map("email_weekly_digest")
  emailScoreUpdates Boolean @default(true) @map("email_score_updates")

  // Interview preferences
  preferredLanguage  String @default("javascript") @map("preferred_language") @db.VarChar(50)
  preferredVoiceLang String @default("en-US") @map("preferred_voice_lang") @db.VarChar(10)

  // Display
  theme     String   @default("system") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// =============================================================================
// AUDIT LOGS
// =============================================================================
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
